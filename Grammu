--// Main Processor
RunService.RenderStepped:Connect(function()
    -- FOV Update
    if Config.FOVVisible then
        FOVCircle.Visible = true
        FOVCircle.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
        FOVCircle.Color = Color3.fromHSV(tick() % 5 / 5, 0.6, 1)
    else FOVCircle.Visible = false end

    -- Aimbot (Safe Smoothing)
    if Config.Aimbot then
        local target = GetTarget()
        if target then
            -- Exponential Smoothing (More human-like)
            local targetCF = CFrame.lookAt(Camera.CFrame.Position, target.Position)
            Camera.CFrame = Camera.CFrame:Lerp(targetCF, 1/Config.Smoothness)
        end
    end

    -- Character Speed
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid.WalkSpeed = Config.WalkSpeed
    end
end)

--// Visuals & Chams Update Loop (0.5s Frequency for Safety)
task.spawn(function()
