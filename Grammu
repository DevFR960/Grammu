Combat:CreateDropdown({Name="Lock Mode",Options={"Smooth","Snap"},Callback=function(v)Config.LockMode=v end})

Visual:CreateToggle({Name="ESP",CurrentValue=false,Callback=function(v)Config.ESP=v end})
Visual:CreateToggle({Name="ESP Box",CurrentValue=true,Callback=function(v)Config.ESPBox=v end})
Visual:CreateToggle({Name="ESP Text",CurrentValue=true,Callback=function(v)Config.ESPText=v end})
Visual:CreateToggle({Name="ESP Highlight",CurrentValue=true,Callback=function(v)Config.ESPHighlight=v end})
