--// SERVICES
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera
local UIS = game:GetService("UserInputService")

--// UI
local Rayfield = loadstring(game:HttpGet("https://sirius.menu/rayfield"))()

--// CONFIG
local Config = {
    Aimbot=false,
    AimPart="Head",
    FOV=200,
    Smoothness=0.2,
    LockMode="Smooth",
    TeamCheck=false,
    WallCheck=false,

    ESP=true,
    ESPBox=true,
    ESPText=true,
    ESPHighlight=true,
    Tracer=true,
    ShowTeam=true,
    ESPDistance=600,

    Hitbox=false,
    HitboxSize=5
}

--// TOGGLE UI
local UIVisible = true
UIS.InputBegan:Connect(function(input,gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.RightShift then
        UIVisible = not UIVisible
        Rayfield:ToggleUI(UIVisible)
    end
end)

--// CACHE
local CachedPlayers={}
task.spawn(function()
    while true do
        CachedPlayers=Players:GetPlayers()
        task.wait(1)
    end
end)

--// TEAM
local function IsEnemy(p)
    if not p.Team or not LocalPlayer.Team then return true end
    return p.Team ~= LocalPlayer.Team
end

local function GetTeamColor(p)
    if p.Team and p.Team.TeamColor then
        return p.Team.TeamColor.Color
    elseif p.TeamColor then
        return p.TeamColor.Color
    end
    return Color3.fromRGB(255,255,255)
end

--// WALL CHECK
local function IsVisible(part,char)
    local origin = Camera.CFrame.Position
    local direction = (part.Position-origin)

    local params = RaycastParams.new()
    params.FilterDescendantsInstances={LocalPlayer.Character}
    params.FilterType=Enum.RaycastFilterType.Blacklist

    local result = workspace:Raycast(origin,direction,params)
    if result then
        return result.Instance:IsDescendantOf(char)
    end
    return true
end

--// ESP STORAGE
local ESP={}

local function CreateESP(p)
    if p==LocalPlayer then return end

    local gui=Instance.new("BillboardGui")
    gui.Size=UDim2.new(4,0,5,0)
    gui.AlwaysOnTop=true
    gui.Parent=game.CoreGui

    local box=Instance.new("Frame",gui)
    box.Size=UDim2.new(1,0,1,0)
    box.BackgroundTransparency=1
    box.BorderSizePixel=2

    local text=Instance.new("TextLabel",gui)
    text.Size=UDim2.new(1,0,0.5,0)
    text.BackgroundTransparency=1
    text.TextScaled=true

    local tracer=Instance.new("Frame",game.CoreGui)
    tracer.Size=UDim2.new(0,2,0,100)
    tracer.AnchorPoint=Vector2.new(0.5,0)

    local hl=Instance.new("Highlight",game.CoreGui)

    ESP[p]={GUI=gui,Box=box,Text=text,Tracer=tracer,HL=hl}
end

local function RemoveESP(p)
    if ESP[p] then
        ESP[p].GUI:Destroy()
        ESP[p].Tracer:Destroy()
        ESP[p].HL:Destroy()
        ESP[p]=nil
    end
end

for _,p in pairs(Players:GetPlayers()) do CreateESP(p) end
Players.PlayerAdded:Connect(CreateESP)
Players.PlayerRemoving:Connect(RemoveESP)

--// AIMBOT OPTIMIZED
local CurrentTarget=nil
local LastUpdate=0

local function GetTarget()
    local closest=nil
    local shortest=Config.FOV

    for i=1,#CachedPlayers do
        local p=CachedPlayers[i]
        if p~=LocalPlayer and p.Character then

            local char=p.Character
            local hum=char:FindFirstChild("Humanoid")

            if hum and hum.Health>0 then
                local part=char:FindFirstChild(Config.AimPart) or char:FindFirstChild("HumanoidRootPart")

                if part then
                    if Config.TeamCheck and not IsEnemy(p) then continue end
                    if Config.WallCheck and not IsVisible(part,char) then continue end

                    local pos,onScreen=Camera:WorldToViewportPoint(part.Position)
                    if onScreen then
                        local dist=(Vector2.new(pos.X,pos.Y)-Vector2.new(Camera.ViewportSize.X/2,Camera.ViewportSize.Y/2)).Magnitude
                        if dist<shortest then
                            shortest=dist
                            closest=part
                        end
                    end
                end
            end
        end
    end

    return closest
end

--// MAIN LOOP
RunService.RenderStepped:Connect(function()

    -- 🔥 update target
    if tick()-LastUpdate > 0.1 then
        CurrentTarget = GetTarget()
        LastUpdate = tick()
    end

    -- AIM
    if Config.Aimbot and CurrentTarget then
        local newCF = CFrame.lookAt(Camera.CFrame.Position,CurrentTarget.Position)

        if Config.LockMode=="Snap" then
            Camera.CFrame=newCF
        else
            Camera.CFrame=Camera.CFrame:Lerp(newCF,Config.Smoothness)
        end
    end

    for i=1,#CachedPlayers do
        local p=CachedPlayers[i]

        if p~=LocalPlayer and p.Character then
            local char=p.Character
            local head=char:FindFirstChild("Head")
            local hum=char:FindFirstChild("Humanoid")
            local root=char:FindFirstChild("HumanoidRootPart")

            local esp=ESP[p]

            if head and hum and esp then
                local pos,onScreen=Camera:WorldToViewportPoint(head.Position)
                local dist=(head.Position-Camera.CFrame.Position).Magnitude

                if Config.ESP and hum.Health>0 and onScreen and dist<Config.ESPDistance then

                    local isEnemy=IsEnemy(p)

                    if not Config.ShowTeam and not isEnemy then
                        esp.GUI.Enabled=false
                        esp.Tracer.Visible=false
                        esp.HL.Enabled=false
                        continue
                    end

                    local color=GetTeamColor(p)
                    if isEnemy then
                        color=color:Lerp(Color3.fromRGB(255,0,0),0.3)
                    end

                    esp.GUI.Adornee=head
                    esp.GUI.Enabled=true

                    esp.Text.Text=p.Name.." | "..math.floor(hum.Health).."HP | "..math.floor(dist).."m"
                    esp.Text.TextColor3=color

                    esp.Box.BorderColor3=color
                    esp.Box.Visible=Config.ESPBox

                    esp.Text.Visible=Config.ESPText

                    esp.HL.Adornee=char
                    esp.HL.FillColor=color
                    esp.HL.OutlineColor=color
                    esp.HL.Enabled=Config.ESPHighlight

                    if Config.Tracer then
                        local center=Vector2.new(Camera.ViewportSize.X/2,Camera.ViewportSize.Y)
                        local d=(center-Vector2.new(pos.X,pos.Y)).Magnitude
                        local ang=math.atan2(pos.Y-center.Y,pos.X-center.X)

                        esp.Tracer.Position=UDim2.new(0,center.X,0,center.Y)
                        esp.Tracer.Size=UDim2.new(0,2,0,d)
                        esp.Tracer.Rotation=math.deg(ang)+90
                        esp.Tracer.BackgroundColor3=color
                        esp.Tracer.Visible=true
                    else
                        esp.Tracer.Visible=false
                    end

                else
                    esp.GUI.Enabled=false
                    esp.Tracer.Visible=false
                    esp.HL.Enabled=false
                end
            end

            -- HITBOX
            if root then
                if Config.Hitbox and IsEnemy(p) then
                    root.Size=Vector3.new(Config.HitboxSize,Config.HitboxSize,Config.HitboxSize)
                    root.Transparency=0.5
                else
                    root.Size=Vector3.new(2,2,1)
                    root.Transparency=1
                end
            end
        end
    end

end)

