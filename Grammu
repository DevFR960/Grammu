--// SERVICES
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera

--// CONFIG
local Config = {
    Aimbot = false,
    TeamCheck = false,
    FOV = 200,
    Smoothness = 5,
    ESP = false,
    Hitbox = false,
    HitboxSize = 5
}

--// UI (ใช้ Instance ล้วน รองรับมือถือ)
local ScreenGui = Instance.new("ScreenGui", game.CoreGui)
local Frame = Instance.new("Frame", ScreenGui)
Frame.Size = UDim2.new(0,200,0,250)
Frame.Position = UDim2.new(0,10,0.3,0)
Frame.BackgroundColor3 = Color3.fromRGB(20,20,20)

local function Button(text,y,callback)
    local b = Instance.new("TextButton",Frame)
    b.Size = UDim2.new(1,0,0,30)
    b.Position = UDim2.new(0,0,0,y)
    b.Text = text
    b.BackgroundColor3 = Color3.fromRGB(40,40,40)
    b.TextColor3 = Color3.new(1,1,1)

    b.MouseButton1Click:Connect(function()
        callback(b)
    end)
end

--// TEAM
local function IsEnemy(p)
    if not Config.TeamCheck then return true end
    return p.Team ~= LocalPlayer.Team
end

--// TARGET
local function GetTarget()
    local target,dist = nil,Config.FOV

    for _,p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Humanoid") then
            local part = p.Character:FindFirstChild("Head")
            if part and IsEnemy(p) then
                local pos,onScreen = Camera:WorldToViewportPoint(part.Position)
                if onScreen then
                    local mag = (Vector2.new(pos.X,pos.Y) - Vector2.new(Camera.ViewportSize.X/2,Camera.ViewportSize.Y/2)).Magnitude
                    if mag < dist then
                        dist = mag
                        target = part
                    end
                end
            end
        end
    end

    return target
end

--// AIMBOT
RunService.RenderStepped:Connect(function()
    if Config.Aimbot then
        local t = GetTarget()
        if t then
            Camera.CFrame = Camera.CFrame:Lerp(
                CFrame.lookAt(Camera.CFrame.Position,t.Position),
                1/Config.Smoothness
            )
        end
    end
end)

--// HITBOX
local function ApplyHitbox(p)
    task.spawn(function()
        while task.wait(0.5) do
            if p.Character and p ~= LocalPlayer then
                local root = p.Character:FindFirstChild("HumanoidRootPart")
                if root then
                    if Config.Hitbox and IsEnemy(p) then
                        root.Size = Vector3.new(Config.HitboxSize,Config.HitboxSize,Config.HitboxSize)
                        root.Transparency = 0.5
                        root.CanCollide = false
                    else
                        root.Size = Vector3.new(2,2,1)
                        root.Transparency = 1
                    end
                end
            end
        end
    end)
end

--// ESP (Highlight แท้ รองรับมือถือ)
local ESP = {}

local function AddESP(p)
    if p == LocalPlayer then return end

    local h = Instance.new("Highlight")
    h.FillColor = Color3.fromRGB(255,0,0)
    h.OutlineColor = Color3.fromRGB(255,255,255)
    h.Parent = game.CoreGui

    ESP[p] = h

    RunService.RenderStepped:Connect(function()
        if Config.ESP and p.Character and IsEnemy(p) then
            h.Adornee = p.Character
            h.Enabled = true
        else
            h.Enabled = false
        end
    end)
end

--// LOAD PLAYERS
for _,p in pairs(Players:GetPlayers()) do
    ApplyHitbox(p)
    AddESP(p)
end

Players.PlayerAdded:Connect(function(p)
    ApplyHitbox(p)
    AddESP(p)
end)

--// UI BUTTONS
Button("Aimbot OFF",0,function(b)
    Config.Aimbot = not Config.Aimbot
    b.Text = "Aimbot "..(Config.Aimbot and "ON" or "OFF")
end)

Button("ESP OFF",35,function(b)
    Config.ESP = not Config.ESP
    b.Text = "ESP "..(Config.ESP and "ON" or "OFF")
end)

Button("Hitbox OFF",70,function(b)
    Config.Hitbox = not Config.Hitbox
    b.Text = "Hitbox "..(Config.Hitbox and "ON" or "OFF")
end)

Button("TeamCheck OFF",105,function(b)
    Config.TeamCheck = not Config.TeamCheck
    b.Text = "TeamCheck "..(Config.TeamCheck and "ON" or "OFF")
end)

Button("FOV +",140,function()
    Config.FOV = Config.FOV + 50
end)

Button("FOV -",175,function()
    Config.FOV = math.max(50,Config.FOV - 50)
end)
