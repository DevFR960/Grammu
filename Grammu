--// CONFIG
local Config = {
    Aimbot=false,
    AimPart="Head",
    Prediction=0.12,

    FOV=250,
    ShowFOV=true,

    TeamCheck=true,
    WallCheck=true,

    ESP=false,
    TextESP=true,
    Tracer=true,
    Highlight=true,
    TeamColor=false,

    Hitbox=false,
    HitboxSize=10,

    WalkSpeed=16,
    JumpPower=50,
    Gravity=196,

