    Callback = function(v) Config.AimPart = v end
})

Combat:CreateDropdown({
    Name = "Lock Mode",
    Options = {"Smooth","Snap"},
    Callback = function(v) Config.LockMode = v end
})

Combat:CreateSlider({
    Name = "Smoothness",
    Range = {5,30},
    Callback = function(v) Config.Smoothness = v/100 end
})

Visual:CreateToggle({
    Name = "ESP",
    CurrentValue = false,
    Callback = function(v) Config.ESP = v end
})

HitboxTab:CreateToggle({
    Name = "Hitbox",
    CurrentValue = false,
    Callback = function(v) Config.Hitbox = v end
})

HitboxTab:CreateSlider({
    Name = "Hitbox Size",
    Range = {2,30},
    Callback = function(v) Config.HitboxSize = v end
})
