})

CombatTab:CreateSlider({
    Name = "Aimbot FOV",
    Range = {50, 800},
    Increment = 1,
    CurrentValue = 200,
    Callback = function(v) Config.FOV = v end
})

CombatTab:CreateSection("Hitbox Settings")
CombatTab:CreateToggle({
    Name = "Hitbox Expander",
    CurrentValue = false,
    Callback = function(v) Config.HitboxEnabled = v end
})

CombatTab:CreateSlider({
    Name = "Hitbox Size",
