--// SERVICES
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera
local UIS = game:GetService("UserInputService")

--// UI
local Rayfield = loadstring(game:HttpGet("https://sirius.menu/rayfield"))()

--// CONFIG
local Config = {
    Aimbot = false,
    AimPart = "Head",
    FOV = 200,
    Smoothness = 0.15,
    LockMode = "Smooth",
    TeamCheck = false,

    Hitbox = false,
    HitboxSize = 5,

    ESP = false
}

--// UI TOGGLE KEY
local UIVisible = true
UIS.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.RightShift then
        UIVisible = not UIVisible
        Rayfield:ToggleUI(UIVisible)
    end
end)

--// PLAYER CACHE
local CachedPlayers = {}
task.spawn(function()
    while true do
        CachedPlayers = Players:GetPlayers()
        task.wait(1)
    end
end)

--// TEAM CHECK
local function IsEnemy(player)
    if not player.Team or not LocalPlayer.Team then return true end
    return player.Team ~= LocalPlayer.Team
end

--// ESP SYSTEM
local ESP = {}

local function CreateESP(player)
    if player == LocalPlayer then return end

    local gui = Instance.new("BillboardGui")
    gui.Size = UDim2.new(4,0,5,0)
    gui.AlwaysOnTop = true
    gui.Enabled = false
    gui.Parent = game.CoreGui

    local text = Instance.new("TextLabel", gui)
    text.Size = UDim2.new(1,0,1,0)
    text.BackgroundTransparency = 1
    text.TextScaled = true

    ESP[player] = {GUI = gui, Text = text}
end

for _, player in pairs(Players:GetPlayers()) do
    CreateESP(player)
end

Players.PlayerAdded:Connect(CreateESP)

--// AIMBOT
local CurrentTarget = nil
local LastUpdate = 0

local function GetTarget()
    local closest = nil
    local shortest = Config.FOV * Config.FOV

    for _, player in ipairs(CachedPlayers) do
        if player ~= LocalPlayer then
            local char = player.Character
            if not char then continue end

            local humanoid = char:FindFirstChild("Humanoid")
            if not humanoid or humanoid.Health <= 0 then continue end

            local part = char:FindFirstChild(Config.AimPart)
            if not part then continue end

            if Config.TeamCheck and not IsEnemy(player) then continue end

            local pos, visible = Camera:WorldToViewportPoint(part.Position)
            if not visible then continue end

            local dx = pos.X - Camera.ViewportSize.X/2
            local dy = pos.Y - Camera.ViewportSize.Y/2
            local dist = dx*dx + dy*dy

            if dist < shortest then
                shortest = dist
                closest = part
            end
        end
    end

    return closest
end

--// HITBOX
local function UpdateHitbox(player)
    if not player.Character then return end

    local root = player.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end

    if Config.Hitbox and IsEnemy(player) then
        root.Size = Vector3.new(Config.HitboxSize, Config.HitboxSize, Config.HitboxSize)
        root.Transparency = 0.5
        root.CanCollide = false
    else
        root.Size = Vector3.new(2,2,1)
        root.Transparency = 1
    end
end

--// MAIN LOOP
local LastESPUpdate = 0

RunService.RenderStepped:Connect(function()

    -- Update target (optimized)
    if tick() - LastUpdate > 0.15 then
        CurrentTarget = GetTarget()
        LastUpdate = tick()
    end

    -- Aimbot
    if Config.Aimbot and CurrentTarget then
        local aimPos = CurrentTarget.Position

        if Config.AimPart == "Head" then
            aimPos = aimPos + Vector3.new(0,0.2,0)
        end

        local newCF = CFrame.lookAt(Camera.CFrame.Position, aimPos)

        if Config.LockMode == "Snap" then
            Camera.CFrame = newCF
        else
            Camera.CFrame = Camera.CFrame:Lerp(newCF, Config.Smoothness)
        end
    end

    -- ESP + Hitbox (optimized)
    if tick() - LastESPUpdate < 0.2 then return end
    LastESPUpdate = tick()

    for _, player in ipairs(CachedPlayers) do
        if player ~= LocalPlayer and player.Character then
            local char = player.Character
            local head = char:FindFirstChild("Head")
            local humanoid = char:FindFirstChild("Humanoid")

            local esp = ESP[player]

            if head and humanoid and esp then
                if Config.ESP and humanoid.Health > 0 then
                    esp.GUI.Enabled = true
                    esp.GUI.Adornee = head
                    esp.Text.Text = player.Name
                else
                    esp.GUI.Enabled = false
                end
            end

            -- Hitbox update
            UpdateHitbox(player)
        end
    end

end)

--// UI
local Window = Rayfield:CreateWindow({Name = "COCO HUB FINAL"})
local Combat = Window:CreateTab("Combat")
local Visual = Window:CreateTab("Visual")
local HitboxTab = Window:CreateTab("Hitbox")

Combat:CreateToggle({
    Name = "Aimbot",
    CurrentValue = false,
    Callback = function(v) Config.Aimbot = v end
})

Combat:CreateDropdown({
