--// SERVICES
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera
local UIS = game:GetService("UserInputService")

--// UI
local Rayfield = loadstring(game:HttpGet("https://sirius.menu/rayfield"))()

--// CONFIG
local Config = {
    Aimbot=false,
    AimPart="Head",
    FOV=200,
    Smoothness=0.2,
    LockMode="Smooth",
    TeamCheck=false,

    ESP=false,
    ESPBox=true,
    ESPText=true,
    ESPHighlight=true,

    Hitbox=false,
    HitboxSize=5
}

--// UI TOGGLE
local UIVisible=true
UIS.InputBegan:Connect(function(input,gp)
    if gp then return end
    if input.KeyCode==Enum.KeyCode.RightShift then
        UIVisible=not UIVisible
        Rayfield:ToggleUI(UIVisible)
    end
end)

--// CACHE
local CachedPlayers={}
task.spawn(function()
    while true do
        CachedPlayers=Players:GetPlayers()
        task.wait(1)
    end
end)

--// TEAM
local function IsEnemy(p)
    if not p.Team or not LocalPlayer.Team then return true end
    return p.Team ~= LocalPlayer.Team
end

local function GetTeamColor(p)
    if p.Team and p.Team.TeamColor then
        return p.Team.TeamColor.Color
    end
    return Color3.fromRGB(255,255,255)
end

--// ESP
local ESP={}

local function CreateESP(p)
    if p==LocalPlayer then return end

    local gui=Instance.new("BillboardGui")
    gui.Size=UDim2.new(4,0,5,0)
    gui.AlwaysOnTop=true
    gui.Enabled=false
    gui.Parent=game.CoreGui

    local box=Instance.new("Frame",gui)
    box.Size=UDim2.new(1,0,1,0)
    box.BackgroundTransparency=1
    box.BorderSizePixel=2

    local text=Instance.new("TextLabel",gui)
    text.Size=UDim2.new(1,0,0.5,0)
    text.BackgroundTransparency=1
    text.TextScaled=true

    local hl=Instance.new("Highlight",game.CoreGui)
    hl.Enabled=false

    ESP[p]={GUI=gui,Box=box,Text=text,HL=hl}
end

for _,p in pairs(Players:GetPlayers()) do CreateESP(p) end
Players.PlayerAdded:Connect(CreateESP)

--// AIM FIX (สำคัญสุด)
local CurrentTarget=nil
local LastAim=0

local function GetTarget()
    local closest=nil
    local shortest=Config.FOV

    for _,p in ipairs(CachedPlayers) do
        if p~=LocalPlayer and p.Character then

            local char=p.Character
            local hum=char:FindFirstChild("Humanoid")

            if hum and hum.Health>0 then

                -- 🔥 เลือก part ตามที่ตั้ง (ไม่มี fallback แล้ว)
                local part = char:FindFirstChild(Config.AimPart)
                if not part then continue end

                if Config.TeamCheck and not IsEnemy(p) then continue end

                local pos,onScreen=Camera:WorldToViewportPoint(part.Position)

                if onScreen then
                    local dist=(Vector2.new(pos.X,pos.Y) -
                        Vector2.new(Camera.ViewportSize.X/2,Camera.ViewportSize.Y/2)).Magnitude

                    if dist < shortest then
                        shortest = dist
                        closest = part
                    end
                end
            end
        end
    end

    return closest
end

--// MAIN LOOP
local LastESP=0

RunService.RenderStepped:Connect(function()

    -- 🔥 AIM UPDATE
    if tick()-LastAim > 0.1 then
        CurrentTarget = GetTarget()
        LastAim = tick()
    end

    -- 🎯 AIM
    if Config.Aimbot and CurrentTarget then
        local aimPos = CurrentTarget.Position

        -- 🔥 แก้หัวเบี้ยว
        if Config.AimPart == "Head" then
            aimPos = aimPos + Vector3.new(0,0.2,0)
        end

        local cf = CFrame.lookAt(Camera.CFrame.Position, aimPos)

        if Config.LockMode=="Snap" then
            Camera.CFrame = cf
        else
            Camera.CFrame = Camera.CFrame:Lerp(cf, Config.Smoothness)
        end
    end

    -- 👁️ ESP
    if tick()-LastESP < 0.1 then return end
    LastESP=tick()

    for _,p in ipairs(CachedPlayers) do
        if p~=LocalPlayer and p.Character then
            local char=p.Character
            local head=char:FindFirstChild("Head")
            local hum=char:FindFirstChild("Humanoid")

            local esp=ESP[p]

            if head and hum and esp then
                if not Config.ESP or hum.Health<=0 then
                    esp.GUI.Enabled=false
                    esp.HL.Enabled=false
                    continue
                end

                local color=GetTeamColor(p)

                esp.GUI.Adornee=head
                esp.GUI.Enabled=true
                esp.Text.Text=p.Name
                esp.Text.TextColor3=color

                esp.Box.BorderColor3=color
                esp.Box.Visible=Config.ESPBox
                esp.Text.Visible=Config.ESPText

                esp.HL.Adornee=char
                esp.HL.FillColor=color
                esp.HL.OutlineColor=color
                esp.HL.Enabled=Config.ESPHighlight
            end
        end
    end

end)

