Visual:CreateToggle({Name="Text ESP",Callback=function(v)Config.TextESP=v end})
Visual:CreateToggle({Name="Tracer",Callback=function(v)Config.Tracer=v end})
Visual:CreateToggle({Name="Highlight",Callback=function(v)Config.Highlight=v end})
Visual:CreateToggle({Name="Show FOV",Callback=function(v)Config.ShowFOV=v end})

Visual:CreateToggle({Name="Team Color",Callback=function(v)Config.TeamColor=v end})
Visual:CreateToggle({Name="Rainbow",Callback=function(v)Config.Rainbow=v end})

