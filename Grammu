--// SERVICES
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera

--// SAFE GUI
local GUIParent = (gethui and gethui()) or game.CoreGui

--// LOAD UI
local ArrayField
pcall(function()
    ArrayField = loadstring(game:HttpGet("https://raw.githubusercontent.com/Hosvile/Refinement/main/MC%3AArrayfield%20Library"))()
end)
if not ArrayField then return end

--// CONFIG
local Config = {
    Aimbot=false,
    AimPart="Head",
    Prediction=0.12,

    FOV=250,
    ShowFOV=true,

    TeamCheck=true,
    WallCheck=true,

    ESP=false,
    TextESP=true,
    Tracer=true,
    Highlight=true,
    TeamColor=false,
    Rainbow=false,

    Hitbox=false,
    HitboxSize=10,

    WalkSpeed=16,
    JumpPower=50,
    Gravity=196,

    SpeedEnabled=false,
    JumpEnabled=false,
    GravityEnabled=false,

    Colors={
        FOV=Color3.fromRGB(0,255,255),
        ESP=Color3.fromRGB(255,0,0)
    }
}

local ESP = {}
local LockedTarget

--// DRAWING
local FOVCircle=nil
pcall(function()
    FOVCircle=Drawing.new("Circle")
    FOVCircle.Thickness=2
    FOVCircle.NumSides=60
    FOVCircle.Filled=false
end)

--// FUNCTIONS
local function InFOV(pos)
    local c=Vector2.new(Camera.ViewportSize.X/2,Camera.ViewportSize.Y/2)
    return (Vector2.new(pos.X,pos.Y)-c).Magnitude<=Config.FOV
end

local function IsEnemy(p)
    if not Config.TeamCheck then return true end
    if not p.Team or not LocalPlayer.Team then return true end
    return p.Team~=LocalPlayer.Team
end

-- ✅ WALLCHECK
local function IsVisible(part, char)
    if not Config.WallCheck then return true end

    local origin = Camera.CFrame.Position
    local direction = (part.Position - origin)

    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {LocalPlayer.Character, char}
    params.FilterType = Enum.RaycastFilterType.Blacklist

    local result = workspace:Raycast(origin, direction, params)
    return result == nil or result.Instance:IsDescendantOf(char)
end

-- TARGET
local function GetTarget()
    local closest,shortest=nil,Config.FOV

    for _,p in pairs(Players:GetPlayers()) do
        if p~=LocalPlayer and p.Character then
            local part=p.Character:FindFirstChild(Config.AimPart)

            if part and IsEnemy(p) and IsVisible(part, p.Character) then
                local pos,vis=Camera:WorldToViewportPoint(part.Position)
                if vis then
                    local dist=(Vector2.new(pos.X,pos.Y)-Vector2.new(Camera.ViewportSize.X/2,Camera.ViewportSize.Y/2)).Magnitude
                    if dist<shortest then
                        shortest=dist
                        closest=part
                    end
                end
            end
        end
    end

    LockedTarget=closest
end

-- HITBOX
local function ApplyHitbox(p)
    if not p.Character then return end
    local root=p.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end

    if Config.Hitbox then
        root.Size=Vector3.new(Config.HitboxSize,Config.HitboxSize,Config.HitboxSize)
        root.Transparency=0.5
        root.CanCollide=false
    else
        root.Size=Vector3.new(2,2,1)
        root.Transparency=0
        root.CanCollide=true
    end
end

-- MOVEMENT
local function ApplyMovement()
    local char=LocalPlayer.Character
    if not char then return end

    local hum=char:FindFirstChildOfClass("Humanoid")
    if not hum then return end

    hum.WalkSpeed = Config.SpeedEnabled and Config.WalkSpeed or 16
    hum.UseJumpPower = true
    hum.JumpPower = Config.JumpEnabled and Config.JumpPower or 50
    workspace.Gravity = Config.GravityEnabled and Config.Gravity or 196.2
end

-- CREATE ESP
local function CreateESP(p)
    if p==LocalPlayer or ESP[p] then return end

    local gui=Instance.new("BillboardGui")
    gui.Size=UDim2.new(4,0,5,0)
    gui.AlwaysOnTop=true
    gui.Parent=GUIParent

    local text=Instance.new("TextLabel",gui)
    text.Size=UDim2.new(1,0,1,0)
    text.BackgroundTransparency=1
    text.TextScaled=true

    local tracer=nil
    pcall(function()
        tracer=Drawing.new("Line")
        tracer.Thickness=1.5
    end)

    local hl=Instance.new("Highlight")
    hl.Parent=GUIParent

    ESP[p]={GUI=gui,Text=text,Tracer=tracer,HL=hl}
end

-- LOOP
RunService.RenderStepped:Connect(function()

    -- FOV
    if FOVCircle then
        FOVCircle.Radius=Config.FOV
        FOVCircle.Position=Vector2.new(Camera.ViewportSize.X/2,Camera.ViewportSize.Y/2)
        FOVCircle.Visible=Config.ShowFOV and Config.Aimbot
        FOVCircle.Color=Config.Rainbow and Color3.fromHSV((tick()%5)/5,1,1) or Config.Colors.FOV
    end

    GetTarget()

    -- AIMBOT
    if Config.Aimbot and LockedTarget then
        local vel=LockedTarget.Velocity or Vector3.new()
        local pred=LockedTarget.Position+(vel*Config.Prediction)
        Camera.CFrame=CFrame.lookAt(Camera.CFrame.Position,pred)
    end

    ApplyMovement()

    for p,v in pairs(ESP) do
        if p.Character then
            local char=p.Character
            local head=char:FindFirstChild("Head")

            ApplyHitbox(p)

            if Config.ESP and head then
                local color=Config.TeamColor and p.TeamColor.Color or Config.Colors.ESP
                if Config.Rainbow then color=Color3.fromHSV((tick()%5)/5,1,1) end

                if Config.TextESP then
                    v.GUI.Adornee=head
                    v.GUI.Enabled=true
                    v.Text.Text=p.Name
                    v.Text.TextColor3=color
                else
                    v.GUI.Enabled=false
                end

                if v.Tracer and Config.Tracer then
                    local pos,vis=Camera:WorldToViewportPoint(head.Position)
                    if vis and InFOV(pos) then
                        v.Tracer.From=Vector2.new(Camera.ViewportSize.X/2,Camera.ViewportSize.Y)
                        v.Tracer.To=Vector2.new(pos.X,pos.Y)
                        v.Tracer.Color=color
                        v.Tracer.Visible=true
                    else
                        v.Tracer.Visible=false
                    end
                end

                if Config.Highlight then
                    v.HL.Adornee=char
                    v.HL.FillColor=color
                    v.HL.Enabled=true
                else
                    v.HL.Enabled=false
                end
            else
                v.GUI.Enabled=false
                if v.Tracer then v.Tracer.Visible=false end
                v.HL.Enabled=false
            end
        end
    end
end)

