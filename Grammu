    end
})

VisualTab:CreateToggle({
    Name = "Green ESP (Legit)",
    CurrentValue = false,
    Callback = function(v) Config.ESP = v end
})

--// Main Processor Loop
RunService.RenderStepped:Connect(function()
    -- 1. FOV Rainbow
    if Config.FOVVisible then
        FOVCircle.Visible = true
        FOVCircle.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
        FOVCircle.Color = Color3.fromHSV(tick() % 5 / 5, 0.8, 1)
    else
        FOVCircle.Visible = false
    end

    -- 2. Legit Aimbot (Interpolation)
    if Config.Aimbot then
        local target = GetTarget()
        if target then
            -- ใช้การหมุนกล้องแบบ Lerp เพื่อความเนียน
            local lookAt = CFrame.lookAt(Camera.CFrame.Position, target.Position)
            Camera.CFrame = Camera.CFrame:Lerp(lookAt, 1 / Config.Smoothness)
        end
    end

    -- 3. Speed & Fly (Mobile Friendly)
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid.WalkSpeed = Config.WalkSpeed
        
        if Config.Fly and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local hrp = LocalPlayer.Character.HumanoidRootPart
            local moveDir = LocalPlayer.Character.Humanoid.MoveDirection
            if moveDir.Magnitude > 0 then
                hrp.Velocity = (Camera.CFrame.LookVector * moveDir.Z + Camera.CFrame.RightVector * moveDir.X).Unit * Config.FlySpeed
            else
                hrp.Velocity = Vector3.new(0, 0.1, 0) -- ต้านแรงโน้มถ่วงเล็กน้อยให้นิ่งขึ้น
            end
        end
    end
end)

--// ESP & Hitbox (Low Frequency Loop for Performance)
task.spawn(function()
    while task.wait(0.5) do
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                -- Hitbox
                if Config.HitboxEnabled and p.Character:FindFirstChild("HumanoidRootPart") then
                    p.Character.HumanoidRootPart.Size = Vector3.new(Config.HitboxSize, Config.HitboxSize, Config.HitboxSize)
                    p.Character.HumanoidRootPart.Transparency = 0.8
                end
                -- ESP
                if Config.ESP then
                    if not p.Character:FindFirstChild("CocoESP") then
                        local hl = Instance.new("Highlight", p.Character)
                        hl.Name = "CocoESP"
                        hl.FillColor = Color3.fromRGB(0, 255, 0)
                        hl.OutlineTransparency = 0.5
                    end
                else
                    if p.Character:FindFirstChild("CocoESP") then p.Character.CocoESP:Destroy() end
                end
            end
        end
    end
end)

