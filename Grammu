local Window=Rayfield:CreateWindow({Name="COCO HUB FINAL LOCK"})
local Combat=Window:CreateTab("Combat")
local Visual=Window:CreateTab("Visual")

Combat:CreateToggle({Name="Aimbot",CurrentValue=false,Callback=function(v)Config.Aimbot=v end})
