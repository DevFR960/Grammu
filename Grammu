--// SERVICES
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera
local UIS = game:GetService("UserInputService")

--// LOAD UI SAFE
local success, Rayfield = pcall(function()
    return loadstring(game:HttpGet("https://sirius.menu/rayfield"))()
end)
if not success then warn("Rayfield Load Failed") return end

--// CONFIG
local Config = {
    Aimbot=false,
    AimPart="Head",
    FOV=200,
    ShowFOV=true,
    Smoothness=0.2,
    Prediction=0.12,

    TeamCheck=true,
    WallCheck=true,

    ESP=false,
    TargetESP=true,
    TextESP=true,
    Tracer=false,
    Highlight=true,

    ESPColor=Color3.fromRGB(255,0,0),
    TeamColor=true,
    Rainbow=false
}

--// CACHE
local CachedPlayers={}
task.spawn(function()
    while true do
        CachedPlayers=Players:GetPlayers()
        task.wait(1)
    end
end)

--// FOV
local FOVCircle=Drawing.new("Circle")
FOVCircle.Thickness=2
FOVCircle.NumSides=50
FOVCircle.Filled=false
FOVCircle.Color=Color3.fromRGB(0,255,255)

--// TEAM
local function IsEnemy(p)
    if not Config.TeamCheck then return true end
    if not p.Team or not LocalPlayer.Team then return true end
    return p.Team~=LocalPlayer.Team
end

--// WALL CHECK
local function IsVisible(part,char)
    if not Config.WallCheck then return true end

    local origin=Camera.CFrame.Position
    local direction=(part.Position-origin)

    local params=RaycastParams.new()
    params.FilterDescendantsInstances={LocalPlayer.Character,char}
    params.FilterType=Enum.RaycastFilterType.Blacklist

    local result=workspace:Raycast(origin,direction,params)
    if result then
        return result.Instance:IsDescendantOf(char)
    end
    return true
end

--// TARGET
local LockedTarget=nil

local function GetTarget()
    if LockedTarget and LockedTarget.Parent then return end

    local closest=nil
    local shortest=Config.FOV*Config.FOV

    for _,p in pairs(CachedPlayers) do
        if p~=LocalPlayer and p.Character then
            local char=p.Character
            local hum=char:FindFirstChild("Humanoid")
            local part=char:FindFirstChild(Config.AimPart)

            if hum and hum.Health>0 and part and IsEnemy(p) and IsVisible(part,char) then
                local pos,vis=Camera:WorldToViewportPoint(part.Position)
                if vis then
                    local dx=pos.X-Camera.ViewportSize.X/2
                    local dy=pos.Y-Camera.ViewportSize.Y/2
                    local dist=dx*dx+dy*dy

                    if dist<shortest then
                        shortest=dist
                        closest=part
                    end
                end
            end
        end
    end

    LockedTarget=closest
end

--// ESP
local ESP={}

local function CreateESP(p)
    if p==LocalPlayer then return end

    local gui=Instance.new("BillboardGui")
    gui.Size=UDim2.new(4,0,5,0)
    gui.AlwaysOnTop=true
    gui.Parent=game.CoreGui

    local text=Instance.new("TextLabel",gui)
    text.Size=UDim2.new(1,0,1,0)
    text.BackgroundTransparency=1
    text.TextScaled=true

    local tracer=Drawing.new("Line")
    tracer.Thickness=2

    local hl=Instance.new("Highlight")
    hl.Parent=game.CoreGui

    ESP[p]={GUI=gui,Text=text,Tracer=tracer,HL=hl}
end

for _,p in pairs(Players:GetPlayers()) do CreateESP(p) end
Players.PlayerAdded:Connect(CreateESP)

--// FIX MEMORY LEAK
Players.PlayerRemoving:Connect(function(p)
    if ESP[p] then
        if ESP[p].GUI then ESP[p].GUI:Destroy() end
        if ESP[p].Tracer then ESP[p].Tracer:Remove() end
        if ESP[p].HL then ESP[p].HL:Destroy() end
        ESP[p]=nil
    end
end)

--// LOOP
local LastTarget=0
local LastESP=0

RunService.RenderStepped:Connect(function()

    -- FOV
    FOVCircle.Radius=Config.FOV
    FOVCircle.Position=Vector2.new(Camera.ViewportSize.X/2,Camera.ViewportSize.Y/2)
    FOVCircle.Visible=Config.ShowFOV and Config.Aimbot

    if Config.Rainbow then
        FOVCircle.Color=Color3.fromHSV((tick()%5)/5,1,1)
    end

    -- TARGET
    if tick()-LastTarget>0.1 then
        GetTarget()
        LastTarget=tick()
    end

    -- AIMBOT
    if Config.Aimbot and LockedTarget then
        local velocity=LockedTarget.Velocity or Vector3.new()
        local predicted=LockedTarget.Position + velocity * Config.Prediction

        local pos,vis=Camera:WorldToViewportPoint(predicted)
        if vis then
            local dx=pos.X-Camera.ViewportSize.X/2
            local dy=pos.Y-Camera.ViewportSize.Y/2
            local dist=dx*dx+dy*dy

            if dist<=Config.FOV*Config.FOV then
                Camera.CFrame = Camera.CFrame:Lerp(
                    CFrame.lookAt(Camera.CFrame.Position,predicted),
                    Config.Smoothness
                )
            end
        end
    end

    -- ESP
    if tick()-LastESP>0.2 then
        LastESP=tick()

        for _,p in pairs(CachedPlayers) do
            if p~=LocalPlayer and p.Character then
                local char=p.Character
                local head=char:FindFirstChild("Head")
                local hum=char:FindFirstChild("Humanoid")
                local esp=ESP[p]

                if not esp then continue end

                local isTarget = (LockedTarget and head == LockedTarget)

                if not Config.ESP or not hum or hum.Health<=0 or (Config.TargetESP and not isTarget) then
                    esp.GUI.Enabled=false
                    esp.Tracer.Visible=false
                    esp.HL.Enabled=false
                else
                    local hp=math.floor(hum.Health)
                    local dist=math.floor((head.Position-Camera.CFrame.Position).Magnitude)

                    local color=Config.ESPColor

                    if Config.TeamColor and p.Team and p.Team.TeamColor then
                        color=p.Team.TeamColor.Color
                    end

                    if Config.Rainbow then
                        color=Color3.fromHSV((tick()%5)/5,1,1)
                    end

                    if isTarget then
                        color=Color3.fromRGB(255,255,0)
                    end

                    -- TEXT
                    if Config.TextESP and head then
                        esp.GUI.Adornee=head
                        esp.GUI.Enabled=true
                        esp.Text.Text="🎯 "..p.Name.." | HP:"..hp.." | "..dist.."m"
                        esp.Text.TextColor3=color
                    else
                        esp.GUI.Enabled=false
                    end

                    -- TRACER
                    if Config.Tracer and head then
                        local pos,vis=Camera:WorldToViewportPoint(head.Position)
                        if vis then
                            esp.Tracer.From=Vector2.new(Camera.ViewportSize.X/2,Camera.ViewportSize.Y)
                            esp.Tracer.To=Vector2.new(pos.X,pos.Y)
                            esp.Tracer.Color=color
                            esp.Tracer.Visible=true
                        else
                            esp.Tracer.Visible=false
                        end
                    else
                        esp.Tracer.Visible=false
                    end

                    -- HIGHLIGHT
                    if Config.Highlight then
                        esp.HL.Adornee=char
                        esp.HL.FillColor=color
                        esp.HL.OutlineColor=color
                        esp.HL.Enabled=true
                    else
                        esp.HL.Enabled=false
                    end
                end
            end
        end
    end

end)

