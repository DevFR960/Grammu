--// Prevent Multiple Executions
if getgenv().CocoHubLoaded then 
    Rayfield:Notify({Title = "Notice", Content = "Script is already running!", Duration = 3})
    return 
end
getgenv().CocoHubLoaded = true

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")
local UIS = game:GetService("UserInputService")
local Camera = workspace.CurrentCamera

--// Load Rayfield Library
local success, Rayfield = pcall(function()
    return loadstring(game:HttpGet("https://sirius.menu/rayfield"))()
end)

if not success then return end

--// Script Settings
local Config = {
    Aimbot = false,
    SilentAim = false,
    AimbotPart = "Head",
    FOV = 100,
    Fly = false,
    FlySpeed = 50,
    WalkSpeed = 16,
    JumpPower = 50,
    HitboxSize = 2,
    ESP = false,
    TeamCheck = false
}

--// FOV Circle Setup
local FOVCircle = Drawing.new("Circle")
FOVCircle.Thickness = 2
FOVCircle.NumSides = 60
FOVCircle.Filled = false
FOVCircle.Transparency = 1
FOVCircle.Color = Color3.fromRGB(255, 255, 255)

--// Functions
local function GetClosestTarget()
    local target = nil
    local shortestDistance = Config.FOV

    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild("Humanoid") and v.Character:FindFirstChild(Config.AimbotPart) then
            if v.Character.Humanoid.Health > 0 then
                -- Team Check Logic
                if Config.TeamCheck and v.Team == LocalPlayer.Team then continue end

                local pos, onScreen = Camera:WorldToViewportPoint(v.Character[Config.AimbotPart].Position)
                if onScreen then
                    local distance = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)).Magnitude
                    if distance < shortestDistance then
                        target = v
                        shortestDistance = distance
                    end
                end
            end
        end
    end
    return target
end

--// UI Window
local Window = Rayfield:CreateWindow({
    Name = "COCO HUB | Universal",
    LoadingTitle = "Loading COCO HUB...",
    LoadingSubtitle = "Created by Dechatorn",
    ConfigurationSaving = {Enabled = false}
})

--// Tabs
local CombatTab = Window:CreateTab("Combat")
local VisualTab = Window:CreateTab("Visuals")
local MovementTab = Window:CreateTab("Movement")

--// Combat Section
CombatTab:CreateToggle({
    Name = "Aimbot (Camera Lock)",
    CurrentValue = false,
    Callback = function(v) Config.Aimbot = v end
})

CombatTab:CreateToggle({
    Name = "Silent Aim",
    CurrentValue = false,
    Callback = function(v) Config.SilentAim = v end
})

CombatTab:CreateDropdown({
    Name = "Target Part",
    Options = {"Head", "HumanoidRootPart"},
    CurrentOption = "Head",
    Callback = function(v) Config.AimbotPart = v end
})

CombatTab:CreateSlider({
    Name = "Field of View (FOV)",
    Range = {30, 800},
    Increment = 1,
    CurrentValue = 100,
    Callback = function(v) Config.FOV = v end
})

--// Visuals Section
VisualTab:CreateToggle({
    Name = "Player ESP (Highlights)",
    CurrentValue = false,
    Callback = function(v) 
        Config.ESP = v 
        if not v then
            for _, p in pairs(Players:GetPlayers()) do
                if p.Character and p.Character:FindFirstChild("CocoHighlight") then
                    p.Character.CocoHighlight:Destroy()
                end
            end
        end
    end
})

--// Movement Section
MovementTab:CreateSlider({
    Name = "WalkSpeed",
    Range = {16, 250},
    Increment = 1,
    CurrentValue = 16,
    Callback = function(v)
        Config.WalkSpeed = v
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
            LocalPlayer.Character.Humanoid.WalkSpeed = v
        end
    end
})

MovementTab:CreateToggle({
    Name = "Flight Mode",
    CurrentValue = false,
    Callback = function(v) Config.Fly = v end
})

--// HOOKS (Silent Aim Logic)
local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    local args = {...}

    if Config.SilentAim and method == "FireServer" then
        -- Common Remote names: "HitPart", "Shoot", "UpdateMouse"
        if tostring(self) == "HitPart" or tostring(self) == "Shoot" then
            local target = GetClosestTarget()
            if target and target.Character then
                args[1] = target.Character[Config.AimbotPart]
                args[2] = target.Character[Config.AimbotPart].Position
                return oldNamecall(self, unpack(args))
            end
        end
    end
    return oldNamecall(self, ...)
end)

--// Main Render Loop
RunService.RenderStepped:Connect(function()
    -- Update FOV Circle
    FOVCircle.Visible = Config.Aimbot or Config.SilentAim
    FOVCircle.Radius = Config.FOV
    FOVCircle.Position = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    FOVCircle.Color = Color3.fromHSV(tick() % 5 / 5, 1, 1)

    -- Aimbot Camera Lock
    if Config.Aimbot then
        local target = GetClosestTarget()
        if target and target.Character then
            local targetPos = target.Character[Config.AimbotPart].Position
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, targetPos)
        end
    end
    
    -- ESP Logic
    if Config.ESP then
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local hl = p.Character:FindFirstChild("CocoHighlight") or Instance.new("Highlight", p.Character)
                hl.Name = "CocoHighlight"
                hl.FillColor = Color3.fromRGB(255, 0, 0)
                hl.OutlineColor = Color3.fromRGB(255, 255, 255)
            end
        end
    end
end)

--// Flight & Physics Loop
RunService.Heartbeat:Connect(function()
    if Config.Fly and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local hrp = LocalPlayer.Character.HumanoidRootPart
        local moveDir = Vector3.new(0,0,0)
        
        if UIS:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + Camera.CFrame.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - Camera.CFrame.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - Camera.CFrame.RightVector end
        if UIS:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + Camera.CFrame.RightVector end
        
        hrp.Velocity = moveDir * Config.FlySpeed
    end
end)

--// Auto-Apply on Respawn
LocalPlayer.CharacterAdded:Connect(function(char)
    local hum = char:WaitForChild("Humanoid")
    task.wait(0.5)
    hum.WalkSpeed = Config.WalkSpeed
end)

Rayfield:Notify({
    Title = "Successfully Loaded",
    Content = "COCO HUB English Edition is ready.",
    Duration = 5
})
