local Visual=Window:CreateTab("Visual")

Combat:CreateToggle({Name="Aimbot",CurrentValue=false,Callback=function(v)Config.Aimbot=v end})
Combat:CreateDropdown({Name="Aim Part",Options={"Head","HumanoidRootPart"},CurrentOption="Head",Callback=function(v)Config.AimPart=v end})
Combat:CreateSlider({Name="Prediction",Range={0,0.5},Increment=0.01,CurrentValue=0.12,Callback=function(v)Config.Prediction=v end})

Visual:CreateToggle({Name="ESP",CurrentValue=false,Callback=function(v)Config.ESP=v end})
Visual:CreateToggle({Name="Target Only",CurrentValue=true,Callback=function(v)Config.TargetESP=v end})
Visual:CreateToggle({Name="Text ESP",CurrentValue=true,Callback=function(v)Config.TextESP=v end})
Visual:CreateToggle({Name="Tracer",CurrentValue=true,Callback=function(v)Config.Tracer=v end})
Visual:CreateToggle({Name="Highlight",CurrentValue=true,Callback=function(v)Config.Highlight=v end})
Visual:CreateToggle({Name="Team Color",CurrentValue=false,Callback=function(v)Config.TeamColor=v end})
Visual:CreateToggle({Name="Rainbow",CurrentValue=false,Callback=function(v)Config.Rainbow=v end})

Visual:CreateSlider({Name="FOV Size",Range={50,800},Increment=10,CurrentValue=250,Callback=function(v)Config.FOV=v end})

Visual:CreateColorPicker({Name="FOV Color",Color=Config.Colors.FOV,Callback=function(v)Config.Colors.FOV=v end})
Visual:CreateColorPicker({Name="ESP Color",Color=Config.Colors.ESP,Callback=function(v)Config.Colors.ESP=v end})
Visual:CreateColorPicker({Name="Target Color",Color=Config.Colors.Target,Callback=function(v)Config.Colors.Target=v end})

-- INIT
for _,p in pairs(Players:GetPlayers()) do CreateESP(p) end
Players.PlayerAdded:Connect(CreateESP)
