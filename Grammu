--// SERVICES
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera

--// UI LIBRARY
local Rayfield = loadstring(game:HttpGet("https://sirius.menu/rayfield"))()

--// CONFIG
local Config = {
    Aimbot = false,
    AimPart = "Head",
    TeamCheck = false,
    WallCheck = false,
    FOV = 200,
    Smoothness = 5,
    ESP = false,
    Hitbox = false,
    HitboxSize = 5
}

--// ANTI-CHEAT LIMITS
local MaxWalkSpeed = 50
local MaxJumpPower = 100

--// TEAM CHECK
local function IsEnemy(player)
    return not Config.TeamCheck or player.Team ~= LocalPlayer.Team
end

--// WALL CHECK
local function IsVisible(part, character)
    if not Config.WallCheck then return true end
    local ray = workspace:Raycast(Camera.CFrame.Position, (part.Position - Camera.CFrame.Position))
    return ray and ray.Instance and ray.Instance:IsDescendantOf(character)
end

--// GET TARGET
local function GetTarget()
    local closestPart = nil
    local shortestDistance = Config.FOV

    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local humanoid = player.Character:FindFirstChild("Humanoid")
            local part = player.Character:FindFirstChild(Config.AimPart)

            if humanoid and part and humanoid.Health > 0 and IsEnemy(player) and IsVisible(part, player.Character) then
                local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)

                if onScreen then
                    local distance = (Vector2.new(screenPos.X, screenPos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude

                    if distance < shortestDistance then
                        shortestDistance = distance
                        closestPart = part
                    end
                end
            end
        end
    end

    return closestPart
end

--// ESP STORAGE
local ESP = {}

local function SetupESP(player)
    if player == LocalPlayer then return end

    local highlight = Instance.new("Highlight")
    highlight.Parent = game.CoreGui

    ESP[player] = highlight
end

for _, player in pairs(Players:GetPlayers()) do
    SetupESP(player)
end

Players.PlayerAdded:Connect(SetupESP)

--// MAIN LOOP
RunService.RenderStepped:Connect(function()

    -- AIMBOT
    if Config.Aimbot then
        local target = GetTarget()
        if target then
            Camera.CFrame = Camera.CFrame:Lerp(
                CFrame.lookAt(Camera.CFrame.Position, target.Position),
                1 / Config.Smoothness
            )
        end
    end

    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then

            local humanoid = player.Character:FindFirstChild("Humanoid")
            local root = player.Character:FindFirstChild("HumanoidRootPart")

            -- ESP
            local esp = ESP[player]
            if esp then
                if Config.ESP and IsEnemy(player) then
                    esp.Adornee = player.Character
                    esp.Enabled = true
                    esp.FillColor = Color3.fromRGB(255, 0, 0)
                else
                    esp.Enabled = false
                end
            end

            -- HITBOX
            if root then
                if Config.Hitbox and IsEnemy(player) then
                    root.Size = Vector3.new(Config.HitboxSize, Config.HitboxSize, Config.HitboxSize)
                    root.Transparency = 0.5
                    root.CanCollide = false
                else
                    root.Size = Vector3.new(2, 2, 1)
                    root.Transparency = 1
                    root.CanCollide = true
                end
            end

            -- ANTI-CHEAT (OTHERS)
            if humanoid then
                if humanoid.WalkSpeed > MaxWalkSpeed then
                    humanoid.WalkSpeed = 16
                end
                if humanoid.JumpPower > MaxJumpPower then
                    humanoid.JumpPower = 50
                end
            end
        end
    end

    -- ANTI-CHEAT (LOCAL PLAYER)
    if LocalPlayer.Character then
        local humanoid = LocalPlayer.Character:FindFirstChild("Humanoid")
        if humanoid then
            if humanoid.WalkSpeed > MaxWalkSpeed then
                humanoid.WalkSpeed = 16
            end
            if humanoid.JumpPower > MaxJumpPower then
                humanoid.JumpPower = 50
            end
        end
    end

end)

--// UI
local Window = Rayfield:CreateWindow({
    Name = "COCO HUB STABLE",
    LoadingTitle = "Loading...",
    ConfigurationSaving = {Enabled = false}
})

local Combat = Window:CreateTab("Combat")
local Visual = Window:CreateTab("Visual")
local HitboxTab = Window:CreateTab("Hitbox")

Combat:CreateToggle({
    Name = "Aimbot",
    Callback = function(v)
        Config.Aimbot = v
    end
})

Combat:CreateDropdown({
    Name = "Aim Part",
    Options = {"Head", "HumanoidRootPart"},
    Callback = function(v)
        Config.AimPart = v
    end
})

Combat:CreateToggle({
    Name = "Team Check",
    Callback = function(v)
        Config.TeamCheck = v
    end
})

Combat:CreateToggle({
    Name = "Wall Check",
    Callback = function(v)
        Config.WallCheck = v
    end
})

Visual:CreateToggle({
    Name = "ESP",
    Callback = function(v)
        Config.ESP = v
    end
})

HitboxTab:CreateToggle({
    Name = "Hitbox",
    Callback = function(v)
        Config.Hitbox = v
    end
})

HitboxTab:CreateSlider({
    Name = "Hitbox Size",
    Range = {2, 50},
    Callback = function(v)
        Config.HitboxSize = v
    end
})
