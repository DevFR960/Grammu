--// SERVICES
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera
local UIS = game:GetService("UserInputService")

--// LOAD RAYFIELD
local Rayfield = loadstring(game:HttpGet("https://sirius.menu/rayfield"))()

--// CONFIG
local Config = {
    Aimbot = false,
    TeamCheck = false,
    FOV = 200,
    Smoothness = 5,
    ESP = false,
    Hitbox = false,
    HitboxSize = 5
}

--// TEAM
local function IsEnemy(p)
    if not Config.TeamCheck then return true end
    return p.Team ~= LocalPlayer.Team
end

--// TARGET
local function GetTarget()
    local target, dist = nil, Config.FOV
    for _,p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Humanoid") then
            local part = p.Character:FindFirstChild("Head")
            if part and IsEnemy(p) then
                local pos,onScreen = Camera:WorldToViewportPoint(part.Position)
                if onScreen then
                    local mag = (Vector2.new(pos.X,pos.Y) - Vector2.new(Camera.ViewportSize.X/2,Camera.ViewportSize.Y/2)).Magnitude
                    if mag < dist then
                        dist = mag
                        target = part
                    end
                end
            end
        end
    end
    return target
end

--// AIMBOT
RunService.RenderStepped:Connect(function()
    if Config.Aimbot then
        local t = GetTarget()
        if t then
            Camera.CFrame = Camera.CFrame:Lerp(
                CFrame.lookAt(Camera.CFrame.Position, t.Position),
                1 / Config.Smoothness
            )
        end
    end
end)

--// HITBOX
local function ApplyHitbox(p)
    task.spawn(function()
        while task.wait(0.5) do
            if p.Character and p ~= LocalPlayer then
                local root = p.Character:FindFirstChild("HumanoidRootPart")
                if root then
                    if Config.Hitbox and IsEnemy(p) then
                        root.Size = Vector3.new(Config.HitboxSize, Config.HitboxSize, Config.HitboxSize)
                        root.Transparency = 0.5
                        root.CanCollide = false
                    else
                        root.Size = Vector3.new(2,2,1)
                        root.Transparency = 1
                    end
                end
            end
        end
    end)
end

--// ESP (Highlight)
local ESP = {}

local function AddESP(p)
    if p == LocalPlayer then return end

    local h = Instance.new("Highlight")
    h.FillColor = Color3.fromRGB(255,0,0)
    h.OutlineColor = Color3.fromRGB(255,255,255)
    h.FillTransparency = 0.5
    h.Parent = game.CoreGui

    ESP[p] = h

    RunService.RenderStepped:Connect(function()
        if Config.ESP and p.Character and IsEnemy(p) then
            h.Adornee = p.Character
            h.Enabled = true
        else
            h.Enabled = false
        end
    end)
end

--// LOAD PLAYERS
for _,p in pairs(Players:GetPlayers()) do
    ApplyHitbox(p)
    AddESP(p)
end

Players.PlayerAdded:Connect(function(p)
    ApplyHitbox(p)
    AddESP(p)
end)

